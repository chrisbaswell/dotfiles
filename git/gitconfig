[user]
	name = Chris Baswell
	email = me@chrisbaswell.com
[mergetool]
	keepBackup = true
[credential]
	helper = osxkeychain
[push]
	default = simple
[core]
	excludesfile = /Users/chris/.dotfiles/git/gitignore_global
[http]
	postBuffer = 1048576000
[grep]
	patternType = perl
[pull]
	ff = only
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
